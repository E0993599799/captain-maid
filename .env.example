# ============================================================================
# CMS Integration
# ============================================================================

# Brand Content Platform API URL
# Development: http://localhost:3001 (when cms-arigeo runs locally)
# Staging: https://cms-staging.vercel.app
# Production: https://cms.company-domain.com
NEXT_PUBLIC_CMS_URL=

# Reserved site identifier for shared content contracts
CMS_SITE_SLUG=captain-maid

# Server-only Payload access token (Bearer JWT)
# Required because the shared CMS collections use authenticatedRead.
CMS_READ_TOKEN=

# Reserved for future draft preview flow
CMS_PREVIEW_SECRET=

# Secret for validating revalidation webhooks from CMS
# Must match backend CAPTAIN_MAID_REVALIDATE_SECRET
REVALIDATE_SECRET=

# ============================================================================
# Analytics & Tracking
# ============================================================================

# Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=

# Vercel Analytics (if using Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ============================================================================
# Localization
# ============================================================================

# Default locale for non-localized routes
DEFAULT_LOCALE=th

# Supported locales (comma-separated)
NEXT_PUBLIC_SUPPORTED_LOCALES=th,en

# Public contact values. Leave empty until marketing confirms the real details.
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_ADDRESS=

# ============================================================================
# Development
# ============================================================================

# Next.js environment
NODE_ENV=development

# Enable debug logging
DEBUG=false

# ============================================================================
# Images & Assets
# ============================================================================

# Image optimization domain (for next/image)
# Must match Vercel Blob domain or Payload media URL
NEXT_PUBLIC_IMAGE_DOMAIN=blob.vercel-storage.com

# Enable image optimization
NEXT_PUBLIC_OPTIMIZE_IMAGES=true
