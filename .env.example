# Environment Variables for Captain Maid

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://captain-maid.vercel.app
NEXT_PUBLIC_SITE_NAME=Captain Maid

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXXXX

# API Endpoints (For future e-commerce integration)
# NEXT_PUBLIC_API_URL=https://api.captain-maid.com
# API_SECRET_KEY=your_api_secret_key

# Email Service (For contact form)
# SENDGRID_API_KEY=SG.xxxx
# SUPPORT_EMAIL=support@captain-maid.com

# Database (For future use)
# DATABASE_URL=postgresql://user:password@localhost:5432/captain-maid

# Payment Gateway (For future e-commerce)
# NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_live_xxxx
# STRIPE_SECRET_KEY=sk_live_xxxx
