# Production Environment Configuration Template
# ⚠️ SECURITY: This is a TEMPLATE ONLY - DO NOT COMMIT ACTUAL SECRETS
#
# Instructions:
# 1. Copy this file to .env.production (local only)
# 2. Fill in actual Supabase credentials
# 3. Set in Vercel dashboard via environment variables
# 4. NEVER commit .env.production to git

NODE_ENV=production

# Database: Supabase Production Project
# Get from: Supabase Dashboard → Settings → Database → Connection String (URI)
# Format: postgres://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgres://postgres:[PASSWORD]@db.[PROD-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Payload CMS Secret (minimum 32 characters)
# Generate: openssl rand -base64 32
# MUST be different from staging/dev
PAYLOAD_SECRET=[GENERATE-NEW-32-CHAR-SECRET-FOR-PROD]

# Vercel Blob Storage Token (for media uploads)
# Get from: Vercel Dashboard → Storage → Blob → Read/Write Token (production)
BLOB_READ_WRITE_TOKEN=[PRODUCTION-BLOB-TOKEN]

# CORS Origins (production domain)
PAYLOAD_CORS_ORIGIN=https://cms-arigeo.vercel.app,https://cms.arigeo.co,https://cms.captainmaid.co

# CSRF Origins (production domain)
PAYLOAD_CSRF_ORIGIN=https://cms-arigeo.vercel.app,https://cms.arigeo.co,https://cms.captainmaid.co

# Production Settings
DEBUG=false
LOG_LEVEL=warn
ENABLE_BACKUPS=true
